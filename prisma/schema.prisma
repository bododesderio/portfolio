generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model SiteContent {
  id        String   @id @default(cuid())
  page      String
  section   String
  fieldKey  String   @map("field_key")
  value     String   @db.Text
  fieldType String   @default("text") @map("field_type") // text | html | image | json | bool
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([page, section, fieldKey])
  @@index([page, section])
  @@map("site_content")
}

model SiteSettings {
  key       String   @id
  value     String   @db.Text
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("site_settings")
}

model Media {
  id         String   @id @default(cuid())
  filename   String
  url        String
  storageId  String   @map("storage_id")
  type       String // image | document
  size       Int
  width      Int?
  height     Int?
  altText    String?  @map("alt_text")
  tags       String[] @default([])
  uploadedAt DateTime @default(now()) @map("uploaded_at")

  // Relations
  clients      Client[]
  testimonials Testimonial[]
  galleryItems GalleryItem[]
  heroImages   HeroImage[]

  @@index([uploadedAt])
  @@map("media")
}

model Service {
  id           String   @id @default(cuid())
  title        String
  description  String   @db.Text
  icon         String
  imageUrl     String?  @map("image_url")
  imageAlt     String?  @map("image_alt")
  homeFeatured Boolean  @default(true) @map("home_featured")
  order        Int      @default(0)
  visible      Boolean  @default(true)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@index([visible, order])
  @@map("services")
}

model Client {
  id          String   @id @default(cuid())
  name        String
  logoMediaId String?  @map("logo_media_id")
  website     String?
  visible     Boolean  @default(true)
  order       Int      @default(0)
  createdAt   DateTime @default(now()) @map("created_at")

  logo Media? @relation(fields: [logoMediaId], references: [id], onDelete: SetNull)

  @@index([visible, order])
  @@map("clients")
}

model Testimonial {
  id           String   @id @default(cuid())
  body         String   @db.Text
  author       String
  role         String
  company      String?
  photoMediaId String?  @map("photo_media_id")
  pages        String[] @default([])
  visible      Boolean  @default(true)
  order        Int      @default(0)
  createdAt    DateTime @default(now()) @map("created_at")

  photo Media? @relation(fields: [photoMediaId], references: [id], onDelete: SetNull)

  @@index([visible, order])
  @@map("testimonials")
}

model BlogPost {
  id                       String    @id @default(cuid())
  title                    String
  slug                     String    @unique
  body                     String    @db.Text
  excerpt                  String    @db.Text
  featuredImageUrl         String    @map("featured_image_url")
  featuredImageAlt         String    @map("featured_image_alt")
  featuredImageAttribution Json?     @map("featured_image_attribution")
  status                   String    @default("draft") // draft | published | scheduled
  category                 String?
  tags                     String[]  @default([])
  publishedAt              DateTime? @map("published_at")
  createdAt                DateTime  @default(now()) @map("created_at")
  updatedAt                DateTime  @updatedAt @map("updated_at")

  @@index([status, publishedAt])
  @@index([category])
  @@map("blog_posts")
}

model GalleryItem {
  id        String   @id @default(cuid())
  mediaId   String   @map("media_id")
  caption   String?
  category  String?
  tags      String[] @default([])
  featured  Boolean  @default(false)
  order     Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")

  media Media @relation(fields: [mediaId], references: [id], onDelete: Cascade)

  @@index([featured, order])
  @@index([category])
  @@map("gallery_items")
}

model Subscriber {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  confirmed    Boolean  @default(false)
  source       String   @default("footer")
  subscribedAt DateTime @default(now()) @map("subscribed_at")

  @@index([confirmed, subscribedAt])
  @@map("subscribers")
}

model NewsletterCampaign {
  id             String    @id @default(cuid())
  subject        String
  bodyHtml       String    @map("body_html") @db.Text
  status         String    @default("draft") // draft | sending | sent
  sentAt         DateTime? @map("sent_at")
  recipientCount Int       @default(0) @map("recipient_count")
  deliveredCount Int       @default(0) @map("delivered_count")
  openCount      Int       @default(0) @map("open_count")
  clickCount     Int       @default(0) @map("click_count")
  bounceCount    Int       @default(0) @map("bounce_count")
  createdAt      DateTime  @default(now()) @map("created_at")

  @@index([status, sentAt])
  @@map("newsletter_campaigns")
}

model Message {
  id         String   @id @default(cuid())
  name       String
  email      String
  subject    String
  body       String   @db.Text
  read       Boolean  @default(false)
  archived   Boolean  @default(false)
  receivedAt DateTime @default(now()) @map("received_at")

  @@index([receivedAt])
  @@index([email])
  @@index([read, archived])
  @@map("messages")
}

model AdminUser {
  id              String    @id @default(cuid())
  email           String    @unique
  name            String?
  avatarUrl       String?   @map("avatar_url")
  passwordHash    String    @map("password_hash")
  lastLogin       DateTime? @map("last_login")
  themePreference String    @default("system") @map("theme_preference") // light | dark | system
  createdAt       DateTime  @default(now()) @map("created_at")

  @@map("admin_users")
}

model PageView {
  id            String   @id @default(cuid())
  path          String
  referrer      String?
  userAgentHash String?  @map("user_agent_hash")
  country       String?
  sessionId     String   @map("session_id")
  createdAt     DateTime @default(now()) @map("created_at")

  @@index([createdAt])
  @@index([path, createdAt])
  @@map("page_views")
}

// Runtime-editable integration config (stored encrypted in DB, overrides env vars)
model AppConfig {
  key       String   @id
  value     String   @db.Text
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("app_config")
}

model SeoSettings {
  page      String   @id
  metaTitle String?  @map("meta_title")
  metaDesc  String?  @map("meta_desc") @db.Text
  ogImage   String?  @map("og_image")
  canonical String?
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("seo_settings")
}

/// Admin-managed press items: essays, articles, awards, speaking engagements.
model PressItem {
  id          String   @id @default(cuid())
  type        String   @default("article") // essay | article | award | speaking
  title       String
  description String   @db.Text
  source      String // e.g. "@NDCUganda", "Daily Monitor"
  sourceUrl   String?  @map("source_url")
  imageUrl    String?  @map("image_url")
  imageAlt    String?  @map("image_alt")
  externalUrl String?  @map("external_url")
  downloadUrl String?  @map("download_url")
  date        String? // e.g. "2024", "March 2024"
  visible     Boolean  @default(true)
  order       Int      @default(0)
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([visible, order])
  @@map("press_items")
}

/// Social embeds pinned to public pages in named sections (e.g. "testimonials", "press-mentions").
model PageEmbed {
  id          String   @id @default(cuid())
  page        String // about | home | services | contact
  section     String // admin-defined slug, e.g. "testimonials"
  sortOrder   Int      @default(0) @map("sort_order")
  platform    String // twitter | instagram | linkedin | facebook | tiktok | youtube | vimeo
  postId      String   @map("post_id") // platform-specific post identifier
  originalUrl String   @map("original_url")
  caption     String?  @db.Text
  isPublished Boolean  @default(true) @map("is_published")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([page, section, sortOrder])
  @@map("page_embeds")
}

/// Admin-managed banners: announcement bars, cookie consent, newsletter prompts, promo modals.
model Banner {
  id             String  @id @default(cuid())
  name           String // admin label (not shown to visitors)
  kind           String // topbar | bottombar | modal | corner | cookie
  placement      String  @default("bottom") // top | bottom | left | right | center
  title          String?
  body           String? @db.Text // supports simple HTML
  imageUrl       String? @map("image_url")
  ctaLabel       String? @map("cta_label")
  ctaUrl         String? @map("cta_url")
  ctaVariant     String  @default("primary") @map("cta_variant") // primary | outline | invert
  dismissable    Boolean @default(true)
  requireConsent Boolean @default(false) @map("require_consent") // cookie-type banners block analytics
  theme          String  @default("auto") // auto | light | dark | brand

  enabled      Boolean   @default(false)
  priority     Int       @default(0)
  startsAt     DateTime? @map("starts_at")
  endsAt       DateTime? @map("ends_at")
  pagesInclude String[]  @default([]) @map("pages_include") // path prefixes; empty = all
  pagesExclude String[]  @default([]) @map("pages_exclude")
  devices      String[]  @default([]) // mobile | tablet | desktop; empty = all

  showOnce       Boolean @default(false) @map("show_once")
  cooldownHours  Int     @default(0) @map("cooldown_hours")
  delaySeconds   Int     @default(0) @map("delay_seconds")
  scrollTrigger  Int?    @map("scroll_trigger") // show after scrolling N%
  exitIntent     Boolean @default(false) @map("exit_intent")
  newsletterHook Boolean @default(false) @map("newsletter_hook") // embed subscribe form

  impressionCount Int @default(0) @map("impression_count")
  clickCount      Int @default(0) @map("click_count")
  dismissCount    Int @default(0) @map("dismiss_count")
  conversionCount Int @default(0) @map("conversion_count")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([enabled, priority])
  @@map("banners")
}

model HeroImage {
  id        String   @id @default(cuid())
  mediaId   String   @map("media_id")
  order     Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")

  media Media @relation(fields: [mediaId], references: [id], onDelete: Cascade)

  @@index([active, order])
  @@map("hero_images")
}

/// Portfolio projects — admin-managed showcase of work.
model Project {
  id               String    @id @default(cuid())
  title            String
  slug             String    @unique
  excerpt          String    @db.Text
  body             String    @db.Text
  featuredImageUrl String?   @map("featured_image_url")
  featuredImageAlt String?   @map("featured_image_alt")
  status           String    @default("planned") // planned | in_progress | completed
  category         String?
  techStack        String[]  @default([]) @map("tech_stack")
  liveUrl          String?   @map("live_url")
  githubUrl        String?   @map("github_url")
  startDate        DateTime? @map("start_date")
  endDate          DateTime? @map("end_date")
  ongoing          Boolean   @default(false)
  visible          Boolean   @default(true)
  featured         Boolean   @default(false)
  order            Int       @default(0)
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  images ProjectImage[]

  @@index([visible, order])
  @@index([status])
  @@map("projects")
}

/// Images attached to a project (gallery).
model ProjectImage {
  id        String   @id @default(cuid())
  projectId String   @map("project_id")
  url       String
  alt       String?
  caption   String?
  order     Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, order])
  @@map("project_images")
}

/// Tracks every email sent by the system (transactional + campaigns).
model EmailLog {
  id          String    @id @default(cuid())
  campaignId  String?   @map("campaign_id")
  to          String
  subject     String
  type        String // campaign | welcome | contact_reply | admin_notify | new_post | digest
  status      String    @default("sent") // sent | delivered | bounced | failed
  postalMsgId String?   @map("postal_msg_id")
  openedAt    DateTime? @map("opened_at")
  clickedAt   DateTime? @map("clicked_at")
  bouncedAt   DateTime? @map("bounced_at")
  deliveredAt DateTime? @map("delivered_at")
  failReason  String?   @map("fail_reason")
  sentAt      DateTime  @default(now()) @map("sent_at")

  events EmailEvent[]

  @@index([campaignId])
  @@index([to])
  @@index([sentAt])
  @@index([type, sentAt])
  @@map("email_logs")
}

/// Individual tracking events (opens, clicks, deliveries, bounces).
model EmailEvent {
  id         String   @id @default(cuid())
  emailLogId String   @map("email_log_id")
  event      String // open | click | delivered | bounced | failed | held
  url        String? // for click events
  ip         String?
  userAgent  String?  @map("user_agent")
  metadata   Json? // extra data from Postal webhooks
  createdAt  DateTime @default(now()) @map("created_at")

  emailLog EmailLog @relation(fields: [emailLogId], references: [id], onDelete: Cascade)

  @@index([emailLogId, event])
  @@map("email_events")
}
