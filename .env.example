# ─── Database ────────────────────────────────────────────────────────────────
# Local Docker: postgresql://bodo:secret@localhost:5432/bodo_portfolio
# Production:   your hosted Postgres URL (Supabase, Neon, RDS, etc.)
DATABASE_URL="postgresql://bodo:secret@localhost:5432/bodo_portfolio"

# ─── NextAuth ────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=""
NEXTAUTH_URL="http://localhost:3000"

# ─── Admin credentials ──────────────────────────────────────────────────────
# Email you'll sign in with.
ADMIN_EMAIL="info@example.com"
# bcrypt hash of the plaintext password. Generate with:
#   node -e "console.log(require('bcryptjs').hashSync('your-pw', 12))"
# This can be overridden at runtime via the admin Integrations settings.
ADMIN_PASSWORD_HASH=""

# ─── Cloudinary (media uploads) ──────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# ─── Resend (transactional email) ────────────────────────────────────────────
RESEND_API_KEY=""

# ─── Public site URL ─────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# ─── Analytics salt ──────────────────────────────────────────────────────────
# Hashes the user-agent string into an anonymous identifier. Rotate to break
# continuity between historical and new data.
# Generate with: openssl rand -hex 32
ANALYTICS_SALT=""

# ─── Unsplash (stock photo fetch script) ─────────────────────────────────────
# Only required when running scripts/fetch-stock-pack.mjs.
# Free dev keys: https://unsplash.com/developers
UNSPLASH_ACCESS_KEY=""
