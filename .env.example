# ─── Which stack this machine runs ───────────────────────────────────────────
# The only command you ever need is:
#
#     docker compose up -d --build
#
# It builds the image, applies migrations, seeds an empty database, and starts
# the app. What it brings up depends on this one variable:
#
#   unset            → compose.yaml       (local dev, hot reload, port 3001)
#   compose.prod.yaml → production stack   (built image, no exposed DB port)
#
# Set this on the production server ONLY. Leave it unset locally.
# COMPOSE_FILE=compose.prod.yaml

# ─── Database ────────────────────────────────────────────────────────────────
# Self-hosted PostgreSQL, run as a container by both stacks. No managed provider.
# Local dev:  postgresql://bodo:secret@localhost:5432/bodo_portfolio
# Production: set automatically from POSTGRES_* vars — do not set manually
DATABASE_URL="postgresql://bodo:secret@localhost:5432/bodo_portfolio"

# ─── NextAuth ────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=""
NEXTAUTH_URL="http://localhost:3001"

# ─── Admin credentials ──────────────────────────────────────────────────────
ADMIN_EMAIL="info@example.com"
# bcrypt hash of the plaintext password. Generate with:
#   node -e "console.log(require('bcryptjs').hashSync('your-pw', 12))"
ADMIN_PASSWORD_HASH=""

# ─── Redis ───────────────────────────────────────────────────────────────────
# Local dev (docker-compose.dev.yml): redis://:devredis@localhost:6379
# Production: set by docker-compose.yml automatically from REDIS_PASSWORD
REDIS_URL="redis://:devredis@localhost:6379"
REDIS_PASSWORD=""

# ─── SMTP (transactional email) ──────────────────────────────────────────────
# Point at any SMTP server: Postal (self-hosted), Mailpit (dev), or any relay.
SMTP_HOST="localhost"
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="Bodo Desderio <noreply@bododesderio.com>"

# ─── Public site URL ─────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL="http://localhost:3001"

# ─── Analytics salt ──────────────────────────────────────────────────────────
# Hashes the user-agent string into an anonymous identifier. Rotate to break
# continuity between historical and new data.
# Generate with: openssl rand -hex 32
ANALYTICS_SALT=""

# ─── Production deployment ───────────────────────────────────────────────────
# Required when COMPOSE_FILE=compose.prod.yaml. That stack refuses to start if
# any of these is missing, rather than falling back to a dev default.
DOMAIN="bododesderio.com"
ACME_EMAIL="info@bododesderio.com"
POSTGRES_DB="bodo_portfolio"
POSTGRES_USER="bodo"
POSTGRES_PASSWORD=""
# Host port the app listens on behind the reverse proxy.
APP_PORT="3000"

# Seeding: auto = seed only when the database is empty (default).
#          true = always seed (overwrites seeded content). false = never.
RUN_SEED_ON_START="auto"

# ─── Postal webhook ──────────────────────────────────────────────────────────
# Currently unset, which means the webhook rejects every request and delivery /
# bounce events are NOT being recorded. Set this to match the secret configured
# in the Postal UI to turn email tracking back on.
POSTAL_WEBHOOK_SECRET=""

# ─── Unsplash (stock photo fetch script) ─────────────────────────────────────
# Only required when running scripts/fetch-stock-pack.mjs.
UNSPLASH_ACCESS_KEY=""
