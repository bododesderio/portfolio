# ─── Database ────────────────────────────────────────────────────────────────
# Local dev (docker-compose.dev.yml): postgresql://bodo:secret@localhost:5432/bodo_portfolio
# Production (docker-compose.yml):    set automatically from POSTGRES_* vars — do not set manually
DATABASE_URL="postgresql://bodo:secret@localhost:5432/bodo_portfolio"

# ─── NextAuth ────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=""
NEXTAUTH_URL="http://localhost:3001"

# ─── Admin credentials ──────────────────────────────────────────────────────
ADMIN_EMAIL="info@example.com"
# bcrypt hash of the plaintext password. Generate with:
#   node -e "console.log(require('bcryptjs').hashSync('your-pw', 12))"
ADMIN_PASSWORD_HASH=""

# ─── Redis ───────────────────────────────────────────────────────────────────
# Local dev (docker-compose.dev.yml): redis://:devredis@localhost:6379
# Production: set by docker-compose.yml automatically from REDIS_PASSWORD
REDIS_URL="redis://:devredis@localhost:6379"
REDIS_PASSWORD=""

# ─── SMTP (transactional email) ──────────────────────────────────────────────
# Point at any SMTP server: Postal (self-hosted), Mailpit (dev), or any relay.
SMTP_HOST="localhost"
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="Bodo Desderio <noreply@bododesderio.com>"

# ─── Public site URL ─────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL="http://localhost:3001"

# ─── Analytics salt ──────────────────────────────────────────────────────────
# Hashes the user-agent string into an anonymous identifier. Rotate to break
# continuity between historical and new data.
# Generate with: openssl rand -hex 32
ANALYTICS_SALT=""

# ─── Production deployment ───────────────────────────────────────────────────
# Required only when running docker-compose.yml (production)
DOMAIN="bododesderio.com"
ACME_EMAIL="info@bododesderio.com"
POSTGRES_DB="bodo_portfolio"
POSTGRES_USER="bodo"
POSTGRES_PASSWORD=""

# ─── Unsplash (stock photo fetch script) ─────────────────────────────────────
# Only required when running scripts/fetch-stock-pack.mjs.
UNSPLASH_ACCESS_KEY=""
